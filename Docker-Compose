services:
  db:
    image: mysql:9.0 # Versão atualizada para 2026
    container_name: lojinha-db
    restart: always
    environment:
      MYSQL_DATABASE: lojinha_db
      MYSQL_ROOT_PASSWORD: root_password
      MYSQL_USER: demon_user
      MYSQL_PASSWORD: demon_password
    ports:
      - "3306:3306"
    healthcheck:
      test: ["CMD", "mysqladmin" ,"ping", "-h", "localhost"]
      timeout: 5s
      retries: 10

  app:
    build: .
    container_name: lojinha-app
    ports:
      - "8080:8080"
    depends_on:
      db:
        condition: service_healthy
    environment:
      - SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/lojinha_db?createDatabaseIfNotExist=true
      - SPRING_DATASOURCE_USERNAME=demon_user
      - SPRING_DATASOURCE_PASSWORD=demon_password
      - SPRING_JPA_HIBERNATE_DDL_AUTO=update